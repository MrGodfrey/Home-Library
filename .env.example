# Local frontend mode.
# local: use browser localStorage for fast offline-style testing.
# api: call /api and rely on the Cloudflare Worker backend or another backend.
# Cover upload to R2 requires api mode plus a running Worker.
VITE_DATA_MODE="local"

# Local development identity shown in the UI when VITE_DATA_MODE=local.
VITE_DEV_ACCESS_EMAIL="local@home-library.dev"

# Optional: if you run a local Cloudflare Worker dev server separately,
# point the Vite dev server at it so /api requests are proxied.
# Example: http://127.0.0.1:8788
VITE_API_PROXY_TARGET=""
